{
  "name": "d2l-to-notebooklm-extension",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:firefox": "node scripts/dev.mjs firefox",
    "dev:chrome": "node scripts/dev.mjs chrome",
    "format": "biome format . --write",
    "format:check": "biome format . --check",
    "lint": "biome lint .",
    "build": "node scripts/build.mjs",
    "build:chrome": "node scripts/build.mjs chrome",
    "build:firefox": "node scripts/build.mjs firefox",
    "build:safari": "node scripts/build.mjs safari",
    "build:watch": "node scripts/watch.mjs",
    "build:watch:chrome": "node scripts/watch.mjs chrome",
    "build:watch:firefox": "node scripts/watch.mjs firefox",
    "build:watch:safari": "node scripts/watch.mjs safari",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.2.4",
    "@types/react-dom": "^19.2.3",
    "@types/webextension-polyfill": "^0.12.0",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.27",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.5.4",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "web-ext": "^9.4.0"
  },
  "packageManager": "pnpm@10.30.2"
}
