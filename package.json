{
  "name": "d2l-to-notebooklm",
  "private": true,
  "scripts": {
    "dev:extension": "pnpm --filter extension dev",
    "build:extension": "pnpm --filter extension build",
    "dev:web": "pnpm --filter web dev",
    "build:web": "pnpm --filter web build",
    "build": "pnpm build:extension && pnpm build:web",
    "typecheck": "pnpm --recursive --if-present run typecheck",
    "format": "biome format . --write",
    "format:check": "biome format .",
    "lint": "pnpm --recursive lint",
    "test": "pnpm --recursive --if-present run test",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,cjs,mjs,json,css,md,html,yml,yaml}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.6",
    "typescript": "^5.5.4"
  },
  "packageManager": "pnpm@10.30.2",
  "engines": {
    "node": "22.x"
  }
}
